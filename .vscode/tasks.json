{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Собрать расширение (VSIX)",
			"type": "npm",
			"script": "package",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Скомпилировать TypeScript",
			"type": "npm",
			"script": "compile",
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent"
			},
			"group": "build"
		},
		{
			"label": "Установить зависимости Node.js",
			"type": "shell",
			"command": "npm install",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"group": "build"
		},
		{
			"label": "Запустить тесты",
			"type": "npm",
			"script": "test",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new",
				"focus": false,
				"clear": true
			},
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"label": "Запустить тесты (с компиляцией и линтом)",
			"type": "npm",
			"script": "pretest",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new",
				"focus": false,
				"clear": true
			},
			"group": "test"
		},
		{
			"label": "Сгенерировать CHANGELOG",
			"type": "npm",
			"script": "changelog",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"group": "build"
		},
		{
			"label": "Обновить каталоги опций vrunner (схемы 2 и 3)",
			"type": "shell",
			"command": "node scripts/gen-vrunner-options.mjs --v3-ref ${input:vrunnerV3Ref}",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	],
	"inputs": [
		{
			"id": "vrunnerV3Ref",
			"type": "promptString",
			"description": "Тег vanessa-runner 3 для каталога опций (пусто — обновить только 2.x)",
			"default": "v3.0.0_rc8"
		}
	]
}
