{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"outDir": "../../out/webviews",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"noEmit": true,
		"types": []
	},
	"include": [
		"./**/*.ts",
		"./**/*.d.ts"
	],
	"exclude": [
		"../../node_modules"
	]
}
